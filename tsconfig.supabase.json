{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@supabase/supabase-js": ["./node_modules/@supabase/supabase-js"]
    }
  },
  "include": ["supabase/functions/**/*.ts", "supabase/functions/**/*.d.ts"]
}
