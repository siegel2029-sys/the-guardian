# Copy this file to `.env` in the project root and set values locally.
# `.env` is gitignored — do not commit secrets.

# --- Google Gemini (browser bundle; prefer a server proxy in production) ---
VITE_GEMINI_API_KEY=
# Optional; default model is used if empty (see geminiClient.ts).
VITE_GEMINI_MODEL=

# --- Clinical alerts (mailto target override) ---
VITE_CLINICAL_ALERT_EMAIL=

# --- Legacy / deprecated (red flag flow uses email; kept for compatibility) ---
VITE_REDFLAGS_WHATSAPP=
