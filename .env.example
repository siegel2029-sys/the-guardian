# Copy to `.env` locally (never commit `.env`).

# Google Gemini (clinical intake / AI)
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.5-flash

# Supabase — must live in `.env` at project root (same folder as package.json).
# No spaces around `=`. Restart `npm run dev` after any change.
# Browser client: anon key only — never put service_role here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
