# Copy to `.env` locally (never commit `.env`).

# Gemini: set only on the server — Supabase Dashboard → Edge Functions → Secrets (or `supabase secrets set`):
#   GEMINI_API_KEY=...
# Optional: GEMINI_MODEL=gemini-2.5-flash

# Supabase — must live in `.env` at project root (same folder as package.json).
# No spaces around `=`. Restart `npm run dev` after any change.
# Browser client: anon key only — never put service_role here.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Local legacy auth only (never use in production builds). Set passwords in `.env`, not in source.
# VITE_USE_LEGACY_AUTH=true
# VITE_DEMO_THERAPIST_A_PASSWORD=
# VITE_DEMO_THERAPIST_B_PASSWORD=
# VITE_DEMO_SEED_PATIENT_PORTAL_PASSWORD=
